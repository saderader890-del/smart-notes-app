# Скопируй этот файл в .env и заполни своими ключами. .env никогда не коммить в git.

PORT=3001

# Ключ OpenAI — используется ТОЛЬКО для транскрипции аудио (Whisper).
# У DeepSeek нет своего Whisper-аналога, поэтому для этой части остаётся OpenAI.
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Ключ DeepSeek — используется для чата с ИИ и function calling (управление вкладками).
# Получить: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# Секрет для проверки токенов пользователей (JWT). Сгенерируй случайную длинную строку, например:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# Максимальный размер загружаемого аудио в мегабайтах (защита от слишком больших файлов)
MAX_AUDIO_MB=300
